# ViralObj — Environment Variables
# Copy to .env and fill in your keys

# Required — Claude API for generate_package
ANTHROPIC_API_KEY=sk-ant-...

# Required — Fal.ai for generate_video (FLUX.2 Pro, MiniMax TTS, VEED Fabric)
FAL_KEY=your-fal-key

# Required for post_to_instagram
INSTAGRAM_ACCESS_TOKEN=your-long-lived-token
INSTAGRAM_ACCOUNT_ID=your-business-account-id

# Optional — Fallback providers for generate_package (provider routing)
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Optional — Provider order for auto routing (default: anthropic,openai,gemini)
VIRALOBJ_PROVIDER_ORDER=anthropic,openai,gemini

# Optional — Model overrides
OPENAI_MODEL=gpt-4.1-mini
GEMINI_MODEL=gemini-2.5-flash

# ─── Bridge server (server.js) — for Gemini Enterprise integration ───────
# Required — token that Gemini Agent sends in X-Gemini-Key header.
# Generate with: openssl rand -hex 32
GEMINI_AGENT_TOKEN=replace-with-long-random-hex

# Optional — port the Express bridge listens on (Railway sets this automatically)
PORT=3001

# Optional — public URL of the bridge (used in openapi.json's server entry).
# Railway exposes this via RAILWAY_PUBLIC_DOMAIN; override here if needed.
PUBLIC_URL=https://viralobj-bridge.up.railway.app

# ─── PostgreSQL (GCP Cloud SQL via src/infrastructure/database.js) ────────
# For Cloud SQL Auth Proxy in socket mode, set DB_HOST to the Unix socket
# path: /cloudsql/<project>:<region>:<instance> — port is ignored.
# For TCP (local dev or private IP), use hostname + port 5432.
DB_HOST=/cloudsql/my-gcp-project:us-central1:viralobj-db
DB_USER=viralobj_app
DB_PASS=replace-me
DB_NAME=viralobj
DB_PORT=5432

# Optional — set to "disable" to turn off TLS (e.g. Unix socket / local dev).
# Default is TLS on with rejectUnauthorized=false, which Cloud SQL over TCP
# expects when you're not pinning the server cert.
DB_SSL=disable

# Optional — connection pool size (default 10). Lower for tiny instances.
DB_POOL_MAX=10

# Optional — "true" logs every query + elapsed ms (DEV ONLY; verbose).
LOG_QUERIES=false

# ─── Google Cloud Storage (src/infrastructure/storage.js) ────────────────
# Bucket for rendered media (video, audio, images). The Bridge mirrors
# Fal/ElevenLabs outputs here so the URLs handed to Gemini are durable
# (Fal CDN URLs expire after ~7 days).
GCS_BUCKET_NAME=viralobj-assets

# Optional — needed only off-GCP (local dev, Railway, Fly). Path to a
# service account JSON key with the 'Storage Object Admin' role on the
# bucket. On Cloud Run / App Engine / GCE / GKE, the runtime's attached
# service account is used automatically (ADC) — leave this unset.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/viralobj-sa.json

# Optional — GCP project id. Usually inferred from ADC on GCP; set
# explicitly when the service account is cross-project.
GCP_PROJECT_ID=my-gcp-project
