# ViralObj — webapp/.env.local
# Copie este arquivo para .env.local e preencha com suas keys

# ─── Supabase (obrigatório) ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── LLM (pelo menos um obrigatório) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AI...

# ─── Provider order (opcional) ───────────────────────────────────────────────
# VIRALOBJ_PROVIDER_ORDER=anthropic,openai,gemini
# OPENAI_MODEL=gpt-4.1-mini
# GEMINI_MODEL=gemini-2.5-flash

# ─── Geração de imagem (mock funciona sem) ───────────────────────────────────
# FAL_KEY=

# ─── Geração de áudio (mock funciona sem) ────────────────────────────────────
# MINIMAX_API_KEY=
# ELEVENLABS_API_KEY=

# ─── Render de vídeo (mock funciona sem) ─────────────────────────────────────
# REMOTION_RENDER_URL=
# VEED_API_KEY=

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Providers: "false" = mock (seguro para dev)
# FAL_INTEGRATION_READY=false
# MINIMAX_READY=false
# ELEVENLABS_READY=false
# REMOTION_READY=false
# FAL_VIDEO_READY=false
# VEED_READY=false

# IP-Adapter (character chaining — requer FAL_INTEGRATION_READY=true)
# FEATURE_IP_ADAPTER=false
# IP_ADAPTER_STRENGTH=0.75

# TTS provider: "elevenlabs" (padrão) ou "minimax"
# TTS_PROVIDER=elevenlabs

# FFmpeg encoding quality
# FFMPEG_CRF=23           # 21 = melhor qualidade, 23 = padrão
# FFMPEG_BITRATE=1500k    # 2000k = melhor qualidade
# FFMPEG_PRESET=fast       # fast (padrão), medium, slow

# Preview mode (pula lip-sync, mais barato)
# FEATURE_PREVIEW_MODE=false

# Logging
# LOG_COSTS=true
# LOG_DURATIONS=true

# ─── Instagram (opcional) ────────────────────────────────────────────────────
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_ACCOUNT_ID=
