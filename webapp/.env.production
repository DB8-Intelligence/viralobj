NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRucXF4bndpd2FxeHRydXZpemd6Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYzNDM5NDMsImV4cCI6MjA5MTkxOTk0M30.63IC17hMy6keE8m_7FWJAawKANEgbxBOy1qsD28w1w8
NEXT_PUBLIC_BRIDGE_API_URL=https://viralobj-bridge-3s77drlfqa-uc.a.run.app
NEXT_PUBLIC_APP_URL=https://www.viralobj.app
