# ViralObj — Environment Variables (Google-Cloud-only)
# All AI services authenticate via Application Default Credentials (ADC).
# No external API keys for Anthropic, Fal, OpenAI or AI-Studio Gemini.

# ─── Bridge server ──────────────────────────────────────────────────────
# Required — shared HMAC token the Gemini Agent sends in X-Gemini-Key.
# Generate with: openssl rand -hex 32
GEMINI_AGENT_TOKEN=replace-with-long-random-hex

# Optional — port (Cloud Run / App Engine inject this automatically)
PORT=8080

# Optional — public base URL used inside openapi.json's `servers[].url`.
# Cloud Run exposes this as `K_SERVICE`-prefixed automatic domain;
# override here only if you bind a custom domain.
PUBLIC_URL=https://viralobj-bridge-<hash>-uc.a.run.app

# ─── Google Cloud (project + ADC) ───────────────────────────────────────
# Required — GCP project for Vertex AI (Gemini + Veo) and Storage.
GCP_PROJECT_ID=my-gcp-project

# Optional — only needed off-GCP (local dev). Path to a service account
# JSON key with roles: aiplatform.user, storage.objectAdmin (on the
# bucket), cloudsql.client. On Cloud Run / App Engine / GCE / GKE the
# runtime's attached service account is used automatically — leave unset.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/viralobj-sa.json

# ─── Vertex AI — Gemini 1.5 Pro (text/package generation) ───────────────
# Optional — defaults shown.
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-1.5-pro

# ─── Vertex AI — Veo (video render) ─────────────────────────────────────
# Optional — defaults shown. Switch to veo-3.0-generate-preview when GA.
VEO_MODEL=veo-2.0-generate-001
VEO_DURATION_SECONDS=8
VEO_MAX_SCENES=4

# ─── Google Cloud Storage ───────────────────────────────────────────────
# Bucket where Veo writes the rendered MP4s (via storageUri) and where
# the Bridge serves them publicly. Bootstrap script grants
# allUsers:objectViewer on this bucket so getPublicUrl() URLs just work.
GCS_BUCKET_NAME=viralobj-assets

# ─── Cloud SQL (Postgres 15) ────────────────────────────────────────────
# For Cloud SQL Auth Proxy in socket mode (Cloud Run default), set
# DB_HOST to /cloudsql/<project>:<region>:<instance> — port is ignored.
# For TCP (local dev), use hostname + port 5432.
DB_HOST=/cloudsql/my-gcp-project:us-central1:viralobj-db
DB_USER=viralobj_app
DB_PASS=replace-me
DB_NAME=viralobj
DB_PORT=5432

# Optional — "disable" to turn off TLS (Unix socket / local dev).
DB_SSL=disable

# Optional — connection pool size (default 10).
DB_POOL_MAX=10

# Optional — "true" logs every SQL query + elapsed ms (DEV ONLY; verbose).
LOG_QUERIES=false
